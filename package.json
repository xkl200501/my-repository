{
  "name": "campus-resource-sharing",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=frontend\" \"npm run dev --workspace=backend\"",
    "start": "npm run start --workspace=backend",
    "build": "npm run build --workspace=frontend && npm run build --workspace=backend",
    "typecheck": "npm run typecheck --workspace=frontend && npm run typecheck --workspace=backend",
    "typecheck:build": "npm run typecheck:build --workspace=frontend && npm run typecheck:build --workspace=backend",
    "lint": "npm run lint --workspace=frontend",
    "db:push": "NODE_TLS_REJECT_UNAUTHORIZED=0 npx drizzle-kit push"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@types/express": "^5.0.1",
    "@types/multer": "^1.4.12",
    "eslint": "^9.9.0",
    "globals": "^15.9.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.0.1",
    "concurrently": "^8.2.2"
  },
  "dependencies": {}
}